{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "default": {
            "()": "uvicorn.logging.DefaultFormatter",
            "fmt": "%(asctime)s - %(levelprefix)s %(message)s",
            "use_colors": false
        }
    },
    "handlers": {
        "file": {
            "class": "logging.FileHandler",
            "filename": "server_output.log",
            "formatter": "default"
        }
    },
    "loggers": {
        "uvicorn": {
            "handlers": ["file"],
            "level": "INFO"
        },
        "uvicorn.error": {
            "level": "INFO",
            "handlers": ["file"]
        },
        "uvicorn.access": {
            "handlers": ["file"],
            "level": "INFO"
        }
    }
}
